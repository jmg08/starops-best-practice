# STAROps SDK environment configuration
# STAROps SDK 环境变量配置
#
# Copy this file to .env and fill in your values.
# 复制本文件为 .env 后填写实际配置。

# -----------------------------------------------------------------------------
# Required service configuration / 必填服务配置
# -----------------------------------------------------------------------------

# Workspace ID / 工作空间 ID
STAROPS_WORKSPACE=your-workspace-id

# STAROps API endpoint / STAROps API 接入点
# Examples / 示例:
#   starops.cn-beijing.aliyuncs.com
#   starops.ap-southeast-1.aliyuncs.com
STAROPS_ENDPOINT=starops.cn-beijing.aliyuncs.com

# -----------------------------------------------------------------------------
# Credential configuration / 凭据配置
# -----------------------------------------------------------------------------

# Recommended: configure credentials with Alibaba Cloud CLI.
# 推荐：使用阿里云 CLI 配置凭据。
#
# If you do not use CLI credentials, uncomment and set AK/SK below.
# 如果不使用 CLI 凭据，可取消下面两行注释并配置 AK/SK。
# ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# -----------------------------------------------------------------------------
# Optional service configuration / 可选服务配置
# -----------------------------------------------------------------------------

# Region, must match STAROPS_ENDPOINT. Default: cn-hangzhou
# 区域，需要与 STAROPS_ENDPOINT 匹配。默认值：cn-hangzhou
STAROPS_REGION=cn-beijing

# Digital employee name. Default: apsara-ops
# 数字员工名称。默认值：apsara-ops
STAROPS_EMPLOYEE_NAME=apsara-ops

# -----------------------------------------------------------------------------
# Optional retry configuration / 可选重试配置
# -----------------------------------------------------------------------------

# Maximum retry attempts for SSE reconnection. Default: 10
# SSE 断线重连最大重试次数。默认值：10
STAROPS_MAX_RETRIES=10

# Idle timeout in seconds before treating the stream as interrupted. Default: 60
# 空闲超时时间，单位秒；超过后视为连接中断。默认值：60
STAROPS_IDLE_TIMEOUT=60

# -----------------------------------------------------------------------------
# Optional logging configuration / 可选日志配置
# -----------------------------------------------------------------------------

# Log level. Valid values: debug, info, warn, error. Default: info
# 日志级别。可选值：debug、info、warn、error。默认值：info
LOG_LEVEL=info

