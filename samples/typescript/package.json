{
  "name": "cms-sdk-samples",
  "version": "1.0.0",
  "description": "Alibaba Cloud CMS SDK samples for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "chat": "tsx src/examples/chat.ts",
    "chat-from-file": "tsx src/examples/chat-from-file.ts",
    "thread-manager": "tsx src/examples/thread-manager.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "alibaba-cloud",
    "cms",
    "sdk",
    "samples"
  ],
