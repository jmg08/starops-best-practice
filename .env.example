# =============================================================================
# CMS SDK Samples - Environment Configuration
# CMS SDK 示例 - 环境配置
# =============================================================================
#
# Copy this file to .env and fill in your actual values
# 复制此文件为 .env 并填入您的实际配置值
#
# =============================================================================

# -----------------------------------------------------------------------------
# Required Variables / 必填变量
# -----------------------------------------------------------------------------

# VIBEOPS_ENDPOINT (Required / 必填)
# Description: The CMS API endpoint address, format: cms.{region-id}.aliyuncs.com
# 描述: CMS API 端点地址，格式: cms.{region-id}.aliyuncs.com
# Example / 示例: cms.cn-hangzhou.aliyuncs.com
VIBEOPS_ENDPOINT=xxx

# ALIBABA_CLOUD_ACCESS_KEY_ID (Required / 必填)
# Description: Your Alibaba Cloud Access Key ID for authentication
# 描述: 用于身份验证的阿里云 Access Key ID
# Note: Keep this value secure and never commit to version control
# 注意: 请妥善保管此值，切勿提交到版本控制系统
# Example / 示例: LTAI5tXXXXXXXXXXXXXX
ALIBABA_CLOUD_ACCESS_KEY_ID=xxx

# ALIBABA_CLOUD_ACCESS_KEY_SECRET (Required / 必填)
# Description: Your Alibaba Cloud Access Key Secret for authentication
# 描述: 用于身份验证的阿里云 Access Key Secret
# Note: Keep this value secure and never commit to version control
# 注意: 请妥善保管此值，切勿提交到版本控制系统
# Example / 示例: XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxx

# -----------------------------------------------------------------------------
# Optional Variables / 可选变量
# -----------------------------------------------------------------------------

# VIBEOPS_REGION (Optional / 可选)
# Description: The region for VibeOps service, must match the endpoint region
# 描述: VibeOps 服务的区域，必须与端点区域匹配
# Default: Extracted from endpoint if not specified
# 默认值: 如未指定，将从端点地址中提取
# Example / 示例: cn-hangzhou
VIBEOPS_REGION=xxx

# VIBEOPS_EMPLOYEE_NAME (Optional / 可选)
# Description: The name of the digital employee to use for chat interactions
# 描述: 用于聊天交互的数字员工名称
# Default / 默认值: apsara-ops
# Example / 示例: my-assistant
VIBEOPS_EMPLOYEE_NAME=apsara-ops

# LOG_LEVEL (Optional / 可选)
# Description: The logging level for the application
# 描述: 应用程序的日志级别
# Valid values / 有效值: debug, info, warn, error
# Default / 默认值: info
# - debug: Detailed debugging information / 详细的调试信息
# - info: General operational information / 一般操作信息
# - warn: Warning messages / 警告信息
# - error: Error messages only / 仅错误信息
# LOG_LEVEL=info
